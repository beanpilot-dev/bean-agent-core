-- id: savings_monthly
-- desc: Monthly income and expenses side by side for savings rate analysis.
--       Aggregate by year+month+account_type. Compute savings = income - expenses per month.
--       Income sums are negative (beancount convention) — negate to get positive income.
-- params:
--   start            period start date inclusive         e.g. 2025-07-01
--   end              period end date exclusive           e.g. 2026-02-01
SELECT year, month, account, sum(position) AS amount
WHERE (account ~ '^Income:' OR account ~ '^Expenses:')
  AND date >= {start} AND date < {end}
GROUP BY year, month, account ORDER BY year, month
