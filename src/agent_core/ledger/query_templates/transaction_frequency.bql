-- id: transaction_frequency
-- desc: Monthly transaction count and total for an account pattern.
--       Distinguishes high-frequency small-amount habits from infrequent large purchases.
--       Divide total by count to get average transaction size per month.
-- params:
--   account_pattern  regex matched against account path  e.g. ^Expenses:Food
--   start            period start date inclusive         e.g. 2025-07-01
--   end              period end date exclusive           e.g. 2026-02-01
SELECT year, month, count(*) AS count, sum(position) AS total
WHERE account ~ '{account_pattern}'
  AND date >= {start} AND date < {end}
GROUP BY year, month ORDER BY year, month
