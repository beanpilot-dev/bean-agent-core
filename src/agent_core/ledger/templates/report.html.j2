<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>月度财务报告 {{ meta.month_label }}</title>
<style>
:root {
    --bg: #0d1117;
    --card: #161b22;
    --border: #30363d;
    --text: #e6edf3;
    --muted: #8b949e;
    --green: #3fb950;
    --red: #f85149;
    --blue: #58a6ff;
    --yellow: #d29922;
    --purple: #bc8cff;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    padding: 2rem;
    max-width: 960px;
    margin: 0 auto;
    line-height: 1.6;
}
h1 { font-size: 1.8rem; margin-bottom: 0.5rem; }
h2 {
    font-size: 1.2rem;
    color: var(--muted);
    margin: 2rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
}
h3 { font-size: 1rem; color: var(--muted); margin: 1.2rem 0 0.6rem; }
.subtitle { color: var(--muted); font-size: 0.9rem; margin-bottom: 2rem; }
.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin-bottom: 2rem;
}
.card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.2rem;
}
.card .label { color: var(--muted); font-size: 0.85rem; margin-bottom: 0.3rem; }
.card .value { font-size: 1.5rem; font-weight: 600; }
.card .sub { color: var(--muted); font-size: 0.8rem; margin-top: 0.3rem; }
table {
    width: 100%;
    border-collapse: collapse;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 1rem;
}
th, td { padding: 0.6rem 1rem; text-align: left; }
th {
    background: rgba(255,255,255,0.05);
    color: var(--muted);
    font-weight: 600;
    font-size: 0.85rem;
    text-transform: uppercase;
}
td { border-top: 1px solid var(--border); }
.num { text-align: right; font-variant-numeric: tabular-nums; }
.green { color: var(--green); }
.red { color: var(--red); }
.muted { color: var(--muted); }
.blue { color: var(--blue); }
.yellow { color: var(--yellow); }

/* Progress bars */
.progress-container {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 1rem;
}
.progress-label {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
}
.progress-bar {
    height: 24px;
    background: rgba(255,255,255,0.05);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    margin-bottom: 0.5rem;
}
.progress-fill {
    height: 100%;
    border-radius: 12px;
    transition: width 0.3s;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 8px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--bg);
    min-width: fit-content;
}
.progress-bar .marker {
    position: absolute;
    top: -4px;
    bottom: -4px;
    width: 3px;
    background: var(--yellow);
    border-radius: 2px;
}
.progress-note { color: var(--muted); font-size: 0.8rem; }

/* Expense bar chart */
.bar-row { display: flex; align-items: center; margin: 0.4rem 0; }
.bar-label { width: 180px; font-size: 0.85rem; flex-shrink: 0; }
.bar-track {
    flex: 1;
    height: 20px;
    background: rgba(255,255,255,0.05);
    border-radius: 4px;
    overflow: hidden;
    margin: 0 0.8rem;
}
.bar-fill { height: 100%; border-radius: 4px; }
.bar-value {
    width: 120px;
    text-align: right;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
}

/* MoM comparison table */
.delta-up-good { color: var(--green); }
.delta-up-bad  { color: var(--red); }
.delta-dn-good { color: var(--green); }
.delta-dn-bad  { color: var(--red); }

@media (max-width: 760px) {
    body { padding: 1rem; }
    .bar-row {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.2rem;
        margin: 0.7rem 0;
    }
    .bar-label, .bar-value { width: auto; }
    .bar-track { margin: 0; }
    .progress-label { flex-direction: column; gap: 0.2rem; }
}
</style>
</head>
<body>
<h1>📊 月度财务报告</h1>
<div class="subtitle">{{ meta.month_label }} · {{ meta.period }} · Generated {{ meta.generated[:16] }}</div>

<!-- ── Summary Cards ── -->
<div class="cards">
  <div class="card">
    <div class="label">💰 本月收入</div>
    <div class="value green">{{ m.income_cny | fmt }}</div>
    <div class="sub">vs 上月 {{ m.income_change | arrow_delta }}</div>
  </div>
  <div class="card">
    <div class="label">💸 本月支出</div>
    <div class="value red">{{ m.expenses_cny | fmt }}</div>
    <div class="sub">vs 上月 {{ m.expense_change | arrow_delta(invert=True) }}</div>
  </div>
  <div class="card">
    <div class="label">🏗️ 固定资产购入</div>
    <div class="value yellow">{{ m.fixed_cny | fmt }}</div>
    <div class="sub">vs 上月 {{ m.fixed_change | arrow_delta(invert=True) }}</div>
  </div>
  <div class="card">
    <div class="label">📈 本月结余</div>
    <div class="value {{ 'green' if m.savings >= 0 else 'red' }}">{{ m.savings | fmt }}</div>
    <div class="sub">储蓄率 {{ "%.1f" | format(m.savings_rate) }}%</div>
  </div>
</div>

<!-- ── Goal Progress ── -->
<h2>🎯 三年目标：流动资金 {{ m.goal_target | fmt }}</h2>
<div class="progress-container">
  <div class="progress-label">
    <span>当前净流动资产: <strong class="{{ 'green' if m.net_liquid >= 0 else 'red' }}">{{ m.net_liquid | fmt }}</strong></span>
    <span>目标: {{ m.goal_target | fmt }}</span>
  </div>
  <div class="progress-bar">
    <div class="progress-fill" style="width:{{ '%.1f' | format(m.goal_pct) }}%;background:{{ 'var(--green)' if m.goal_pct >= m.elapsed_pct else 'var(--red)' }}">
      {{ "%.1f" | format(m.goal_pct) }}%
    </div>
    <div class="marker" style="left:{{ '%.1f' | format(m.elapsed_pct) }}%" title="时间进度 {{ '%.1f' | format(m.elapsed_pct) }}%"></div>
  </div>
  <div class="progress-label">
    <span class="progress-note">⏱️ 时间进度: {{ goal.months_elapsed }}/{{ goal.total_months }} 月 ({{ "%.1f" | format(m.elapsed_pct) }}%)</span>
    <span class="progress-note">{{ '🟢 超前' if m.goal_pct >= m.elapsed_pct else '🔴 落后' }}</span>
  </div>
  <div class="progress-note" style="margin-top:0.5rem">
    剩余 {{ goal.months_remaining }} 个月，每月需净存 <strong>{{ m.monthly_needed | fmt }}</strong> 才能达标
  </div>
</div>

<!-- ── Net Worth ── -->
<h2>🏦 资产负债快照</h2>
<div class="cards">
  <div class="card">
    <div class="label">流动资产</div>
    <div class="value blue">{{ m.liquid_cny | fmt }}</div>
  </div>
  <div class="card">
    <div class="label">固定资产</div>
    <div class="value yellow">{{ m.fixed_total | fmt }}</div>
  </div>
  <div class="card">
    <div class="label">负债</div>
    <div class="value red">{{ m.liabilities_cny | fmt }}</div>
  </div>
  <div class="card">
    <div class="label">净资产</div>
    <div class="value {{ 'green' if m.net_worth >= 0 else 'red' }}">{{ m.net_worth | fmt }}</div>
  </div>
</div>

<h3>流动资产明细</h3>
<table>
<tr><th>账户</th><th class="num">余额</th></tr>
{% for row in q.liquid_snapshot.rows %}
<tr><td>{{ row.account | short_account }}</td><td class="num">{{ row.total | amt }}</td></tr>
{% endfor %}
</table>

<h3>负债明细</h3>
<table>
<tr><th>账户</th><th class="num">余额</th></tr>
{% for row in q.liabilities.rows %}
<tr><td>{{ row.account | short_account }}</td><td class="num red">{{ row.total | amt }}</td></tr>
{% endfor %}
</table>

<h3>固定资产明细</h3>
<table>
<tr><th>账户</th><th class="num">累计价值</th></tr>
{% for row in q.fixed_snapshot.rows %}
<tr><td>{{ row.account | short_account }}</td><td class="num">{{ row.total | amt }}</td></tr>
{% endfor %}
</table>

<!-- ── Expense Breakdown Bar Chart ── -->
<h2>💸 支出构成（含固定资产购入）</h2>
{% set bar_colors = ["#f85149","#f0883e","#d29922","#3fb950","#58a6ff","#bc8cff","#8b949e","#6e7681"] %}
{% for label, value, pct, share in outflow_bars %}
<div class="bar-row">
  <div class="bar-label">{{ label }}</div>
  <div class="bar-track"><div class="bar-fill" style="width:{{ '%.1f' | format(pct) }}%;background:{{ bar_colors[loop.index0 % bar_colors|length] }}"></div></div>
  <div class="bar-value">{{ value | fmt }} ({{ "%.0f" | format(share) }}%)</div>
</div>
{% endfor %}

<!-- ── Income Detail ── -->
<h2>💰 收入明细</h2>
<table>
<tr><th>科目</th><th class="num">金额</th></tr>
{% for row in q.income.rows %}
<tr><td>{{ row.account | short_account }}</td><td class="num green">{{ row.amount | amt }}</td></tr>
{% endfor %}
<tr style="font-weight:600"><td>合计</td><td class="num green">{{ m.income_cny | fmt }}</td></tr>
</table>

<h3>本月最大收入 Top 5</h3>
<table>
<tr><th>日期</th><th>描述</th><th>科目</th><th class="num">金额</th></tr>
{% for row in q.top_inflows.rows %}
<tr>
  <td>{{ row.date }}</td>
  <td>{{ row.narration }}</td>
  <td>{{ row.account | short_account }}</td>
  <td class="num green">{{ row.amount | amt }}</td>
</tr>
{% endfor %}
</table>

<!-- ── Expense Detail ── -->
<h2>💸 支出明细</h2>
<table>
<tr><th>科目</th><th class="num">本月</th><th class="num">上月</th><th class="num">变化</th></tr>
{% for row in q.expenses.rows %}
{% set prev_amt = prev_expense_by_account.get(row.account, 0) %}
{% set cur = row.amount | cny %}
{% set delta = cur - prev_amt %}
<tr>
  <td>{{ row.account | short_account }}</td>
  <td class="num red">{{ row.amount | amt }}</td>
  <td class="num muted">{{ prev_amt | fmt }}</td>
  <td class="num">{{ delta | arrow_delta(invert=True) }}</td>
</tr>
{% endfor %}
<tr style="font-weight:600">
  <td>合计</td>
  <td class="num red">{{ m.expenses_cny | fmt }}</td>
  <td class="num muted">{{ m.prev_expenses | fmt }}</td>
  <td class="num">{{ m.expense_change | arrow_delta(invert=True) }}</td>
</tr>
</table>

{% if q.fixed_purchases.rows %}
<h3>固定资产购入明细</h3>
<table>
<tr><th>科目</th><th class="num">金额</th></tr>
{% for row in q.fixed_purchases.rows %}
<tr><td>{{ row.account | short_account }}</td><td class="num yellow">{{ row.amount | amt }}</td></tr>
{% endfor %}
<tr style="font-weight:600"><td>合计</td><td class="num yellow">{{ m.fixed_cny | fmt }}</td></tr>
</table>
{% endif %}

<!-- ── Top Outflows ── -->
<h2>🔝 Top 5 最大支出</h2>
<table>
<tr><th>日期</th><th>描述</th><th>科目</th><th class="num">金额</th></tr>
{% for row in q.top_outflows.rows %}
<tr>
  <td>{{ row.date }}</td>
  <td>{{ row.narration }}</td>
  <td>{{ row.account | short_account }}</td>
  <td class="num red">{{ row.position | amt }}</td>
</tr>
{% endfor %}
</table>

</body>
</html>
