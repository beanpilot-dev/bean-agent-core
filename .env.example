# Repository mode: cloud requires request OAuth credentials; local uses LOCAL_REPO_URL.
AGENT_MODE=cloud
LOCAL_REPO_URL=

# Clone cache TTL in seconds. 0 disables reuse; -1 never expires entries.
WORKSPACE_TTL_SECONDS=900

# Optional model and tracing configuration
OPENAI_MODEL=gpt-4o
LANGFUSE_ENABLED=false
OPENAI_BASE_URL=platform.openai.com